{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": [
      "zh"
    ],
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true,
        "category": "ai-infrastructure"
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true,
        "category": "ai-infrastructure"
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true,
        "category": "ai-infrastructure"
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150,
      "category": "ai-industry"
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "Google Research",
        "url": "https://research.google/blog/rss/",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 60,
          "category": "ai-research"
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 60,
          "category": "ai-tools"
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20,
          "category": "ai-industry"
        }
      ]
    },
    "google_news": {
      "enabled": true,
      "query": "人工智能 OR 大模型 OR AI智能体 OR 多模态 OR AI科研 OR AI编程",
      "language": "zh-CN",
      "country": "CN",
      "ceid": "CN:zh-Hans",
      "max_results": 30,
      "category": "ai-industry"
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "focus": "只收录与人工智能直接相关的内容：基础模型与多模态、AI Agent、AI 编程、用于物理学习与科研的 AI 工具、重要开源项目、模型评测、安全治理和产业变化。AWS 计费、普通数据库技巧、天文学等内容如果没有明确的 AI 方法或影响，必须视为离题。目标读者是一名希望用 AI 提升物理学习和科研能力的中国物理系本科生。",
    "max_items": 24,
    "category_groups": {
      "research": {
        "limit": 8,
        "categories": [
          "ai-research"
        ]
      },
      "tools": {
        "limit": 8,
        "categories": [
          "ai-tools",
          "ai-infrastructure",
          "github-trending"
        ]
      },
      "industry": {
        "limit": 8,
        "categories": [
          "ai-industry"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 3
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
